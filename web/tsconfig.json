{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@parsers/*": ["./lib/it/parsers/*"],
      "@utility/*": ["./lib/it/utility/*"],
      "@website-data": ["./lib/it/data/website-data.json"],
      "@components/*": ["./lib/it/_stubs/components/*"],
      "@hooks/*": ["./lib/it/_stubs/hooks/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "scripts",
    "lib/it/utility/generate-sitemap.mjs",
    "lib/it/utility/createEmotionCache.js",
    "lib/it/utility/builds"
  ]
}
